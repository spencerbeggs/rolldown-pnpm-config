{
	"name": "rolldown-pnpm-config",
	"version": "0.5.0",
	"private": true,
	"description": "A dogfooding example of our plugin",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/rolldown-pnpm-config.git",
		"directory": "package"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./runtime": "./src/runtime/index.ts",
		"./virtual": {
			"types": "./src/virtual.d.ts"
		},
		"./package.json": "./package.json"
	},
	"bin": {
		"rolldown-pnpm-config": "./src/cli/bin.ts"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "turbo run build:dev",
		"types:check": "tsc --noEmit"
	},
	"dependencies": {
		"@effect/platform-node": "catalog:effect",
		"@effected/semver": "^0.2.0",
		"@effected/yaml": "^0.5.0",
		"effect": "catalog:effect",
		"ink": "^7.1.1",
		"ink-tab": "^5.2.0",
		"oxc-parser": "^0.141.0",
		"react": "catalog:silk",
		"std-env": "^4.2.0",
		"std-osc8": "^0.2.0"
	},
	"devDependencies": {
		"@savvy-web/bundler": "^2.0.6",
		"@types/node": "catalog:silk",
		"@types/react": "catalog:silk",
		"ink-testing-library": "^4.0.0",
		"rolldown": "catalog:silk",
		"typescript": "catalog:silk"
	},
	"peerDependencies": {
		"rolldown": "catalog:silkPeers"
	},
	"peerDependenciesMeta": {
		"rolldown": {
			"optional": true
		}
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
