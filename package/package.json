{
	"name": "rolldown-pnpm-config",
	"version": "0.2.0",
	"private": true,
	"description": "A dogfooding example of our plugin",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/rolldown-pnpm-config.git",
		"directory": "package"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./runtime": "./src/runtime/index.ts",
		"./virtual": {
			"types": "./src/virtual.d.ts"
		},
		"./package.json": "./package.json"
	},
	"bin": {
		"rolldown-pnpm-config": "./src/cli/bin.ts"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "turbo run build:dev",
		"types:check": "tsgo --noEmit"
	},
	"dependencies": {
		"@effect/cli": "^0.75.2",
		"@effect/cluster": "^0.59.0",
		"@effect/experimental": "^0.60.0",
		"@effect/platform": "^0.96.2",
		"@effect/platform-node": "^0.107.0",
		"@effect/printer": "^0.49.0",
		"@effect/printer-ansi": "^0.49.0",
		"@effect/rpc": "^0.75.1",
		"@effect/sql": "^0.51.1",
		"@effect/typeclass": "^0.40.0",
		"@effect/workflow": "^0.18.2",
		"effect": "catalog:silk",
		"ink": "^7.1.0",
		"ink-tab": "^5.2.0",
		"oxc-parser": "^0.138.0",
		"react": "^19.2.7",
		"semver-effect": "^0.3.1",
		"std-env": "^4.1.0",
		"std-osc8": "^0.2.0",
		"yaml": "^2.9.0"
	},
	"devDependencies": {
		"@savvy-web/bundler": "^1.1.6",
		"@types/node": "^26.0.0",
		"@types/react": "^19.2.17",
		"@typescript/native-preview": "catalog:silk",
		"ink-testing-library": "^4.0.0",
		"rolldown": "^1.1.3",
		"typescript": "catalog:silk"
	},
	"peerDependencies": {
		"rolldown": "^1.1.0"
	},
	"peerDependenciesMeta": {
		"rolldown": {
			"optional": true
		}
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
