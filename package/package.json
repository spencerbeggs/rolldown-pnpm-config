{
	"name": "rolldown-pnpm-config",
	"version": "0.0.0",
	"private": true,
	"description": "A dogfooding example of our plugin",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/rolldown-pnpm-config.git",
		"directory": "package"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./runtime": "./src/runtime/index.ts",
		"./package.json": "./package.json"
	},
	"bin": {
		"rolldown-pnpm-config": "./src/cli/index.ts"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "turbo run build:dev",
		"types:check": "tsgo --noEmit"
	},
	"dependencies": {
		"effect": "^3.21.4"
	},
	"devDependencies": {
		"@savvy-web/bundler": "^0.11.0",
		"@types/node": "catalog:silk",
		"@typescript/native-preview": "catalog:silk",
		"rolldown": "^1.1.2",
		"typescript": "catalog:silk"
	},
	"peerDependencies": {
		"rolldown": "^1.1.2"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
