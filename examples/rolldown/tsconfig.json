{
	"$schema": "https://json.schemastore.org/tsconfig.json",
	"compilerOptions": {
		"esModuleInterop": true,
		"lib": ["es2023"],
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"noEmit": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "es2023",
		"types": ["node"],
		"verbatimModuleSyntax": true
	},
	"include": ["src", "rolldown.config.ts", "pnpm-config.ts"]
}
